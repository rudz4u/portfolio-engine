# Copy this file to `.env.local` and fill in real secrets. NEVER commit `.env.local`.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Upstox (OAuth client credentials)
UPSTOX_CLIENT_ID=your_upstox_client_id
UPSTOX_CLIENT_SECRET=your_upstox_client_secret
UPSTOX_REDIRECT_URI=https://your-app/api/upstox/callback
# Direct access token (bypasses OAuth for sandbox mode)
UPSTOX_ACCESS_TOKEN=
UPSTOX_SANDBOX=true

# LLM / AI Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Tavily / Web Search
TAVILY_API_KEY=

# App settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
