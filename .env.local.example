# Copy this file to `.env.local` and fill in real secrets. NEVER commit `.env.local`.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# Upstox (OAuth client credentials)
UPSTOX_CLIENT_ID=your_upstox_client_id
UPSTOX_CLIENT_SECRET=your_upstox_client_secret
UPSTOX_REDIRECT_URI=https://your-app/callback/upstox

# LLM / AI Keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=ak-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIza...    # if using Google APIs
GEMINI_API_KEY=gm-xxxxxxxxxxxxxxxx

# Tavily / Web Search
TAVILY_API_KEY=tv-xxxxxxxxxxxxxxxxxxxxxxxx

# Email provider (Brevo / SendGrid)
BREVO_API_KEY=brv-xxxxxxxxxxxxxxxxxxxxxxxx

# Misc
NEXT_PUBLIC_APP_URL=http://localhost:3000
